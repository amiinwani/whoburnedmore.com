{
  "name": "whoburnedmore",
  "version": "1.1.0",
  "description": "🔥 Know exactly how many tokens — and dollars — your AI coding agents burned. A fast, 100% local CLI that parses your Claude Code & OpenAI Codex session transcripts into a token-and-cost report. No account, no upload, zero network calls.",
  "type": "module",
  "bin": {
    "whoburnedmore": "dist/cli.js"
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "build": "node scripts/build.mjs",
    "typecheck": "tsc --noEmit",
    "test": "node --import tsx --test test/*.test.ts",
    "start": "node dist/cli.js",
    "prepare": "npm run build || true"
  },
  "keywords": [
    "claude",
    "claude-code",
    "tokens",
    "token-usage",
    "ai",
    "cli",
    "cost",
    "llm",
    "usage",
    "anthropic"
  ],
  "homepage": "https://whoburnedmore.com",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/amiinwani/whoburnedmore.com.git"
  },
  "bugs": {
    "url": "https://github.com/amiinwani/whoburnedmore.com/issues"
  },
  "license": "MIT",
  "devDependencies": {
    "@types/node": "^20.14.0",
    "esbuild": "^0.28.1",
    "tsx": "^4.19.0",
    "typescript": "^5.5.0"
  }
}
